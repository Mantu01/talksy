# Talksy API Backend Environment Variables
# Copy this file to '.env' and fill in your custom values.

# Server Port
PORT=5000

# Environment (development/production)
NODE_ENV=development

# MongoDB Connection URI
MONGODB_URI=mongodb://127.0.0.1:27017/talksy

# JWT Sign/Verify Secret Key
JWT_SECRET=your_super_secure_jwt_secret_key_here

# Cloudinary Storage Configuration
# Signup at https://cloudinary.com to get these keys.
# (If not specified, uploads will fall back to local disk storage in public/uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
