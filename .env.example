# ==============================================================================
# TALKSY GLOBAL ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# Copy this file to individual application directory .env files as specified below.
# ==============================================================================

# ------------------------------------------------------------------------------
# API BACKEND CONFIGURATION
# Location: apps/api/.env
# Description: Configures the Express server, MongoDB connection, JWT security,
# and Cloudinary file upload service.
# ------------------------------------------------------------------------------

# The port where the backend Express & WebSocket server will run
PORT=5000

# The environment state of the Node server ('development' or 'production')
NODE_ENV=development

# MongoDB Connection string URI (Local instance or Atlas cloud cluster)
MONGODB_URI=mongodb://127.0.0.1:27017/talksy

# JSON Web Token Secret key used to sign and verify client sessions
JWT_SECRET=your_super_secure_jwt_secret_key_here

# Cloudinary Integration (Required for profile and group media uploads)
# Sign up at https://cloudinary.com/ to get your credentials.
# Note: If Cloudinary fails, the server will fallback to local folder uploads automatically.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ------------------------------------------------------------------------------
# MOBILE APP FRONTEND CONFIGURATION
# Location: apps/mobile/.env
# Description: Configures the Expo Client API endpoint.
# ------------------------------------------------------------------------------

# The base url to reach the backend REST API.
# Note: On physical Android and iOS devices, Talksy's api client dynamically replaces 'localhost'
# with the developer machine's local IP address out-of-the-box for easy debugging.
EXPO_PUBLIC_API_URL=http://localhost:5000/api
